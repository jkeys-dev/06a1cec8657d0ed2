{
  "compilerOptions": {
    "target": "es2024",
    "lib": ["es2024"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "rootDir": "./src",
    "esModuleInterop": true,
    "outDir": "./build",
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules/**/*"]
}
